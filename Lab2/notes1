import numpy as np
from scipy.ndimage import convolve1d

def multiscale_gabor_laplace(video, sigma_0=4, taph_0=1.5, scale_step=np.sqrt(2), N=4, method='Local-Maxima'):
    """
    Multiscale Gabor-Laplace: 
    Χρησιμοποιεί φίλτρα Gabor για χωροχρονικό εντοπισμό και το LoG για επιλογή κλίμακας.
    """
    # Δημιουργία των διανυσμάτων κλίμακας
    sigma_vector = [sigma_0 * (scale_step**i) for i in range(N)]
    taph_vector = [taph_0 * (scale_step**i) for i in range(N)]
    
    # Λίστα για αποθήκευση των Scale-Normalized LoG 
    LoG_table = []
    
    # Πυρήνας 2ης παραγώγου για τον υπολογισμό της Λαπλασιανής
    laplacian_kernel = np.array([1, -2, 1])
    
    print("--- Υπολογισμός LoG Scale-Space ---")
    for i in range(N):
        sigma = sigma_vector[i]
        taph = taph_vector[i]
        
        # 1. Εξομάλυνση στην τρέχουσα κλίμακα
        L = apply_3d_gaussian_filter(video, sigma, sigma, taph)
        
        # 2. Υπολογισμός 2ων παραγώγων στους 3 άξονες
        Lxx = convolve1d(input=L, weights=laplacian_kernel, axis=1)
        Lyy = convolve1d(input=L, weights=laplacian_kernel, axis=0)
        Ltt = convolve1d(input=L, weights=laplacian_kernel, axis=2)
        
        # 3. Υπολογισμός Scale-Normalized 3D LoG: σ^2(Lxx + Lyy) + τ^2(Ltt)
        LoG = np.abs((sigma**2) * (Lxx + Lyy) + (taph**2) * Ltt)
        LoG_table.append(LoG)
        
    final_points = []
    
    print("\n--- Εντοπισμός Gabor & Επιλογή Κλίμακας LoG ---")
    for i in range(N):
        print(f"Επεξεργασία κλίμακας {i+1}/{N} (sigma={sigma_vector[i]:.2f}, taph={taph_vector[i]:.2f})")
        
        # Κλήση της δικής σου συνάρτησης Gabor μονής κλίμακας
        candidates = gabor_detector(
            video=video, 
            sigma=sigma_vector[i], 
            taph=taph_vector[i], 
            method=method, 
            plot_H=False
        )
        
        # Έλεγχος των υποψήφιων σημείων στον άξονα της κλίμακας (LoG)
        for pt in candidates:
            x, y, t = int(round(pt[0])), int(round(pt[1])), int(round(pt[2]))
            
            # Ασφαλής έλεγχος ορίων του βίντεο
            if (y >= video.shape[0] or x >= video.shape[1] or t >= video.shape[2] or
                y < 0 or x < 0 or t < 0):
                continue
            
            # Τιμή LoG του σημείου στην τρέχουσα κλίμακα
            current_LoG = LoG_table[i][y, x, t]
            
            # Τιμές LoG στην προηγούμενη και επόμενη κλίμακα
            next_LoG = LoG_table[i+1][y, x, t] if i + 1 < N else -1
            prev_LoG = LoG_table[i-1][y, x, t] if i - 1 > -1 else -1
            
            # Scale Selection: Αν είναι τοπικό μέγιστο κατά μήκος του άξονα της κλίμακας
            if current_LoG > next_LoG and current_LoG > prev_LoG:
                # Αποθηκεύουμε [x, y, t] μαζί με τις κλίμακες εντοπισμού
                final_points.append([x, y, t, sigma_vector[i], taph_vector[i]])
                
    final_array = np.array(final_points)
    print(f"\nΣυνολικά βρέθηκαν {final_array.shape[0]} πολυ-κλιμακωτά σημεία (Gabor-Laplace).")
    
    return final_array
