import os
import imageio

# 1. Όρισε τον φάκελο με τις εικόνες και το όνομα του τελικού GIF
input_folder = 'test_results'  # Βάλε τον δικό σου φάκελο (π.χ. 'test_save' ή 'test_multiscale')
output_gif = 'my_tracking_result.gif'

# 2. Πάρε τη λίστα με τα αρχεία εικόνων και ταξινόμησέ τα αλφαβητικά
# Κρατάμε μόνο τα αρχεία με κατάληξη .png (ή .jpg αν τα έχεις σώσει έτσι)
images_list = [img for img in os.listdir(input_folder) if img.endswith('.png')]
images_list.sort()  # Η ταξινόμηση δουλεύει τέλεια χάρη στο {t:03d} format που είχες κάνει!

# 3. Διάβασε όλες τις εικόνες στη μνήμη
frames = []
for file_name in images_list:
    file_path = os.path.join(input_folder, file_name)
    frames.append(imageio.imread(file_path))

# 4. Αποθήκευσε το GIF
# Η παράμετρος fps (frames per second) ελέγχει την ταχύτητα αναπαραγωγής.
# Για το δικό σου βίντεο, 15-30 fps είναι συνήθως μια χαρά.
imageio.mimsave(output_gif, frames, fps=15)

print(f"Το GIF αποθηκεύτηκε επιτυχώς: {output_gif}")
